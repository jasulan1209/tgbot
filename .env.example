# ─── Telegram ─────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=incognito
MYSQL_PASSWORD=strongpassword
MYSQL_DB=incognito_bot

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Admin API ────────────────────────────────────────────────────────────────
ADMIN_SECRET_KEY=change-me-in-production-use-long-random-string
ADMIN_API_PORT=8000

# ─── Anti-spam ────────────────────────────────────────────────────────────────
SPAM_MAX_MESSAGES=10
SPAM_WINDOW_SECONDS=10
